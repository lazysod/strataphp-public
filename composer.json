{
    "name": "lazysod/strataphp",
    "description": "A lightweight, modular PHP framework with automatic module discovery, PSR-4 autoloading, and comprehensive CLI tools.",
    "type": "project",
    "version": "1.2.0",
    "keywords": [
        "php",
        "framework",
        "modular",
        "psr-4",
        "mvc",
        "cli",
        "modules"
    ],
    "homepage": "https://github.com/lazysod/strataphp-dev",
    "license": "MIT",
    "authors": [
        {
            "name": "Barry",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/lazysod/strataphp-dev/issues",
        "source": "https://github.com/lazysod/strataphp-dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "public_html/app/",
            "App\\Controllers\\": "public_html/controllers/",
            "App\\Models\\": "public_html/models/",
            "App\\Modules\\": "public_html/modules/",
            "App\\Modules\\Api\\Controllers\\": "public_html/modules/api/Controllers/Api/",
            "App\\Modules\\Api\\Tests\\": "public_html/modules/api/Tests/",
            "App\\Modules\\OAuthClients\\Controllers\\": "public_html/modules/OAuthClients/controllers/",
            "App\\Modules\\OAuthClients\\Models\\": "public_html/modules/OAuthClients/models/",
            "App\\Modules\\StrataCms\\Controllers\\": "public_html/modules/StrataCms/Controllers/",
            "App\\Modules\\StrataCms\\Models\\": "public_html/modules/StrataCms/Models/",
            "App\\Modules\\ModuleDirectory\\Controllers\\": "public_html/modules/module_directory/controllers/",
            "App\\Modules\\ModuleDirectory\\Models\\": "public_html/modules/module_directory/models/",
            "App\\Modules\\GoogleAnalytics\\Controllers\\": "public_html/modules/GoogleAnalytics/Controllers/",
            "App\\Modules\\GoogleAnalytics\\Models\\": "public_html/modules/GoogleAnalytics/Models/"
        }
    },
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^7.0",
        "twig/twig": "^3.21",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.13"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "*": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"echo 'Autoloader updated successfully.\\n';\""
        ],
        "create-module": [
            "@php bin/create-module.php"
        ],
        "install-module": [
            "@php bin/install-module.php"
        ],
        "migrate": [
            "@php bin/migrate.php"
        ],
        "create-admin": [
            "@php bin/create_admin.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
